    @Override
    public {{className}}Response getById(String id) {
        {{entityName}} entity = {{instanceName}}Mapper.selectById(id);
        if (entity == null) {
            throw new BusinessException(ErrorCode.READER_NOT_FOUND);  // 按需替换错误码
        }
        return convertToResponse(entity);
    }

    @Override
    @Transactional
    @Auditable(action = "UPDATE")
    public {{className}}Response update(String id, {{className}}Request request) {
        {{entityName}} entity = {{instanceName}}Mapper.selectById(id);
        if (entity == null) {
            throw new BusinessException(ErrorCode.READER_NOT_FOUND);
        }
        // entity.setXxx(request.getXxx());
        {{instanceName}}Mapper.updateById(entity);
        return convertToResponse(entity);
    }

    @Override
    @Transactional
    @Auditable(action = "DELETE")
    public void delete(String id) {
        {{entityName}} entity = {{instanceName}}Mapper.selectById(id);
        if (entity == null) {
            throw new BusinessException(ErrorCode.READER_NOT_FOUND);
        }
        {{instanceName}}Mapper.deleteById(id);
    }

    // ---- 私有工具方法 ----

    /**
     * Entity → Response DTO 转换
     * 为什么要转换？
     *   数据库表结构（Entity）和 API 响应（DTO）是两套模型。
     *   表结构变时只改 Entity，API 兼容性靠 DTO 屏蔽——前端不受影响。
     */
    private {{className}}Response convertToResponse({{entityName}} entity) {
        {{className}}Response response = new {{className}}Response();
        // response.setXxx(entity.getYyy());
        return response;
    }
