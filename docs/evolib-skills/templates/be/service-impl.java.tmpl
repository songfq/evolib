 */
@Service
@RequiredArgsConstructor
@Slf4j
public class {{className}}ServiceImpl implements {{className}}Service {

    private final {{mapperName}}Mapper {{instanceName}}Mapper;
    private final AuditService auditService;

    @Override
    @Transactional
    @Auditable(action = "CREATE")
    public {{className}}Response create({{className}}Request request) {
        // Step 1: 参数校验
        if (request == null) {
            throw new BusinessException(ErrorCode.INVALID_PARAM);
        }

        // Step 2: 业务逻辑校验（唯一性、存在性等）

        // Step 3: 数据写入
        {{entityName}} entity = new {{entityName}}();
        // entity.setXxx(request.getXxx());  ← 将 DTO 字段映射到 Entity
        {{instanceName}}Mapper.insert(entity);

        // Step 4: 包装返回
        return convertToResponse(entity);
    }

