import com.evolib.module.{{moduleName}}.dto.{{className}}Request;
import com.evolib.module.{{moduleName}}.dto.{{className}}Response;
import com.evolib.module.{{moduleName}}.service.{{className}}Service;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
