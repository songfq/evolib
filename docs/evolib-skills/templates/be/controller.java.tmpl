     */
    @GetMapping("/search")
    @PreAuthorize("hasAnyRole('{{role}}')")
    public Result<PageResult<{{className}}Response>> search(
            @RequestParam String keyword,
            @RequestParam(defaultValue = "1") int page,
            @RequestParam(defaultValue = "10") int size) {
        log.info("{{功能}}搜索: keyword={}, page={}", keyword, page);
        PageResult<{{className}}Response> result = {{instanceName}}Service.search(keyword, page, size);
        return Result.ok(result);
    }

