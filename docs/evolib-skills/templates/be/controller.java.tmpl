 */
@RestController
@RequestMapping("/api/v1/{{pathPrefix}}")
@RequiredArgsConstructor
@Slf4j
public class {{className}}Controller {

    private final {{className}}Service {{instanceName}}Service;

    /**
     * {{接口功能描述}}
     * POST /api/v1/{{pathPrefix}}
     */
    @PostMapping
    @PreAuthorize("hasRole('{{role}}')")
    public Result<{{className}}Response> create(@RequestBody @Valid {{className}}Request request) {
        log.info("{{功能}}请求: {}", request);
        {{className}}Response response = {{instanceName}}Service.create(request);
        return Result.ok(response);
    }

